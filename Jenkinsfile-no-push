pipeline {
    agent any

    tools {
        nodejs 'nodejs'
    }

    environment {
        IMAGE_NAME = "kinganish/simple-devops-app"
    }

    stages {

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('SonarCloud Scan') {
            steps {

                script {

                    def scannerHome = tool 'sonar-scanner'

                    withCredentials([string(
                        credentialsId: 'sonar-token',
                        variable: 'SONAR_TOKEN'
                    )]) {

                        bat """
                        ${scannerHome}\\bin\\sonar-scanner.bat ^
                        -Dsonar.projectKey=Anish2324_assignment_Dev ^
                        -Dsonar.organization=anish2324 ^
                        -Dsonar.sources=. ^
                        -Dsonar.host.url=https://sonarcloud.io ^
                        -Dsonar.login=%SONAR_TOKEN%
                        """
                    }
                }
            }
        }

        stage('Trivy Scan') {
            steps {

                bat '''
                "C:\\Users\\Anish\\Downloads\\trivy_0.70.0_windows-64bit\\trivy.exe" fs ^
                --severity HIGH,CRITICAL ^
                .
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t %IMAGE_NAME% .'
            }
        }

        stage('Test') {
            steps {
                echo 'Pipeline without Docker Push working'
            }
        }
    }   
}